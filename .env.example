# MongoDB Configuration
MONGODB_URL=mongodb://localhost/pagine_azzurre
# For MongoDB Atlas Cloud use: mongodb+srv://username:password@cluster.mongodb.net/dbname

# JWT Secret (REQUIRED - Use a strong random string in production)
# Generate with: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Web3 / Blockchain Configuration
# Infura Project ID for Ethereum Goerli Testnet
WEB3_INFURA_URL=wss://goerli.infura.io/ws/v3/YOUR_INFURA_PROJECT_ID
WEB3_NETWORK_ID=5

# SendGrid Email Service
SENDGRID_API_KEY=your-sendgrid-api-key

# PayPal Configuration
PAYPAL_CLIENT_ID=your-paypal-client-id

# Google Maps API
GOOGLE_API_KEY=your-google-maps-api-key

# AWS S3 Configuration (for file uploads)
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_BUCKET_NAME=your-bucket-name

# Server Configuration
PORT=5050
NODE_ENV=development

# Security: Seed Endpoints
# By default, seed endpoints (/api/users/seed, /api/products/seed) are only available in development
# Set to 'true' to explicitly enable them in production (NOT RECOMMENDED)
ALLOW_SEED=false
