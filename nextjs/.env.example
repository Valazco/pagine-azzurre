# API Configuration
# IMPORTANT: In production, set this to your backend API URL
NEXT_PUBLIC_API_URL=http://localhost:5050

# Environment
NODE_ENV=development

# ===== NOTES FOR DEPLOYMENT =====
#
# For Vercel deployment:
# 1. Set NEXT_PUBLIC_API_URL to your production backend URL
#    Example: https://api.pagineazzurre.net
#
# 2. Make sure your backend is accessible from the internet
#    Options:
#    - Deploy backend to a service (Railway, Render, DigitalOcean, AWS, etc.)
#    - Use ngrok for testing
#    - Use Vercel serverless functions (requires migration)
#
# 3. Add environment variables in Vercel dashboard:
#    Project Settings > Environment Variables
#
# 4. Backend must have CORS configured to allow your Vercel domain
