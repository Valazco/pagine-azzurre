# ===========================================
# Next.js API Routes - Environment Variables
# ===========================================

# Database
MONGODB_URL=mongodb+srv://user:password@cluster.mongodb.net/pagineazzurre

# NextAuth.js
NEXTAUTH_SECRET=your-super-secret-key-min-32-chars
NEXTAUTH_URL=http://localhost:3000

# Mailtrap Email
MAILTRAP_API_KEY=your-mailtrap-api-key
MAILTRAP_SENDER_EMAIL=noreply@pagineazzurre.it
MAILTRAP_SENDER_NAME=Pagine Azzurre
# Optional: Mailtrap template UUIDs
MAILTRAP_TEMPLATE_VERIFICATION=
MAILTRAP_TEMPLATE_WELCOME=
MAILTRAP_TEMPLATE_RECOVERY=
MAILTRAP_TEMPLATE_PASSWORD_CHANGED=
MAILTRAP_TEMPLATE_NEWSLETTER=
MAILTRAP_TEMPLATE_ORDER_OFFERER=
MAILTRAP_TEMPLATE_ORDER_BUYER=
MAILTRAP_TEMPLATE_ORDER_MAILING=

# Blockchain / Crypto
TOKEN_CONTRACT_ADDRESS=0x...
ENTROPY=random-string-for-wallet-generation

# AWS S3 (for file uploads)
AWS_REGION=eu-west-1
S3_KEY_ID=your-aws-access-key-id
S3_ACCESS_KEY=your-aws-secret-access-key
S3_BUCKET_NAME=pagineazzurre2

# PayPal
PAYPAL_CLIENT_ID=sb

# Google Maps
NEXT_PUBLIC_GOOGLE_API_KEY=your-google-maps-api-key

# Web3 / Infura (for frontend Wagmi)
NEXT_PUBLIC_INFURA_URL=https://goerli.infura.io/v3/xxx
NEXT_PUBLIC_INFURA_SEPOLIA_URL=https://sepolia.infura.io/v3/xxx

# Environment
NODE_ENV=development
